---
import { siteConfig } from '../data/site';

const { lang, t } = Astro.props;
---

<section id="download" class="relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700 to-transparent"></div>

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-brand-500/5 blur-[100px]"></div>

  <div class="section-container relative z-10">
    <div class="reveal text-center">
      <h2 class="section-title">{t['download.title']}</h2>
      <p class="section-subtitle mx-auto">{t['download.desc']}</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-3 max-w-3xl mx-auto">
      {siteConfig.platforms.map((platform, i) => (
        <a
          href={siteConfig.github + '/releases/latest'}
          target="_blank"
          rel="noopener noreferrer"
          class={`reveal reveal-delay-${i + 1} group relative rounded-2xl border border-slate-800 bg-slate-900/50 p-6 text-center transition-all duration-300 hover:border-brand-500/50 hover:bg-slate-800/50 hover:shadow-xl hover:shadow-brand-500/10`}
        >
          <!-- Platform icon -->
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-slate-800 text-slate-300 transition-colors group-hover:bg-brand-500/10 group-hover:text-brand-400" set:html={platform.icon} />

          <!-- Platform name -->
          <h3 class="text-lg font-semibold text-slate-100">{platform.name}</h3>

          <!-- Version badge -->
          <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-400">
            <span>v{siteConfig.version}</span>
            <span class="text-slate-600">·</span>
            <span>{platform.size}</span>
          </div>

          <!-- Download arrow -->
          <div class="mt-4 flex items-center justify-center gap-2 text-sm font-medium text-brand-400 opacity-0 transition-opacity group-hover:opacity-100">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t['hero.download']}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

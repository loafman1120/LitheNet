---
import { siteConfig } from '../data/site';

const { lang, t } = Astro.props;
---

<section id="download" class="relative">
  <div class="section-container relative z-10">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="section-title">{t['download.title']}</h2>
      <p class="section-subtitle mx-auto">{t['download.desc']}</p>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl gap-px overflow-hidden rounded-lg border border-slate-800/80 bg-slate-800/35 shadow-2xl shadow-black/20 backdrop-blur-sm sm:grid-cols-3">
      {siteConfig.platforms.map((platform, i) => (
        <a
          href={siteConfig.github + '/releases/latest'}
          target="_blank"
          rel="noopener noreferrer"
          class={`reveal reveal-delay-${i + 1} group relative bg-[#0a0e12]/68 p-6 backdrop-blur-sm transition-colors duration-300 hover:bg-brand-300/[0.045]`}
        >
          <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-md border border-slate-700 bg-slate-950/50 text-slate-300 transition-colors group-hover:border-brand-200/30 group-hover:text-brand-100" set:html={platform.icon} />

          <h3 class="text-base font-semibold text-slate-100">{platform.name}</h3>

          <div class="mt-3 inline-flex items-center gap-1.5 font-mono text-xs text-slate-500">
            <span>v{siteConfig.version}</span>
            <span class="text-slate-600">·</span>
            <span>{platform.size}</span>
          </div>

          <div class="mt-5 flex items-center gap-2 text-sm font-medium text-brand-200 opacity-80 transition-opacity group-hover:opacity-100">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            {t['hero.download']}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

---
import FeatureCard from './FeatureCard.astro';

const { lang, t } = Astro.props;

const features = [
  { icon: 'hub', title: t['features.proxy.title'], desc: t['features.proxy.desc'] },
  { icon: 'rss', title: t['features.subs.title'], desc: t['features.subs.desc'] },
  { icon: 'receipt', title: t['features.logs.title'], desc: t['features.logs.desc'] },
  { icon: 'palette', title: t['features.theme.title'], desc: t['features.theme.desc'] },
];
---

<section id="features" class="relative">
  <div class="section-container">
    <div class="reveal max-w-2xl">
      <h2 class="section-title">{t['features.title']}</h2>
      <p class="section-subtitle !mx-0">{t['screenshots.desc']}</p>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-lg border border-slate-800/80 bg-slate-800/35 shadow-2xl shadow-black/20 backdrop-blur-sm sm:grid-cols-2">
      {features.map((f, i) => (
        <FeatureCard title={f.title} desc={f.desc} icon={f.icon} index={i} />
      ))}
    </div>
  </div>
</section>

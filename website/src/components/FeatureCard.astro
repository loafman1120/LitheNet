---
const { title, desc, icon, index } = Astro.props;

const icons: Record<string, string> = {
  hub: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect x="2" y="7" width="6" height="6" rx="1"/><rect x="16" y="7" width="6" height="6" rx="1"/><circle cx="12" cy="17" r="3"/><line x1="5" y1="13" x2="12" y2="14"/><line x1="19" y1="13" x2="12" y2="14"/></svg>`,
  rss: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>`,
  receipt: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M14 8h.01"/><path d="M8 12h.01"/><path d="M14 16h.01"/><path d="M8 20h.01"/></svg>`,
  palette: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
};

const delayClass = `reveal-delay-${(index % 4) + 1}`;
---

<div class={`reveal ${delayClass} group relative rounded-lg border border-slate-800/75 bg-[#0a0f14]/68 p-6 backdrop-blur-sm transition-all duration-300 hover:border-brand-300/30 hover:bg-brand-300/[0.045]`}>
  <div class="mb-5 inline-flex items-center justify-center rounded-md border border-brand-200/15 bg-brand-300/10 p-2.5 text-brand-200 transition-colors group-hover:border-brand-200/30">
    <Fragment set:html={icons[icon] || icons.hub} />
  </div>

  <h3 class="text-base font-semibold text-slate-50">{title}</h3>

  <p class="mt-3 text-sm leading-7 text-slate-400">{desc}</p>

  <div class="pointer-events-none absolute inset-x-6 bottom-0 h-px bg-gradient-to-r from-transparent via-brand-200/0 to-transparent transition-colors group-hover:via-brand-200/40"></div>
</div>

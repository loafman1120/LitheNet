---
import { siteConfig } from '../data/site';

const { lang, t } = Astro.props;
---

<footer class="relative border-t border-slate-800">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-500 text-xs font-extrabold text-white">
          LN
        </div>
        <span class="text-lg font-bold text-slate-100">LitheNet</span>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-slate-400">
        <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          {t['footer.github']}
        </a>
        <span class="text-slate-600">·</span>
        <a href={siteConfig.singbox} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white">
          sing-box
        </a>
        <span class="text-slate-600">·</span>
        <span>{t['footer.license']}</span>
      </div>

      <!-- Credits -->
      <div class="text-xs text-slate-500">
        {t['footer.thanks']} <a href={siteConfig.singbox} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">sing-box</a>
      </div>
    </div>
  </div>
</footer>

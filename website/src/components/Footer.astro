---
import { siteConfig } from '../data/site';

const { lang, t } = Astro.props;
---

<footer class="relative border-t border-slate-800/90">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col items-center gap-6 md:flex-row md:justify-between">
      <div class="flex items-center gap-2.5">
        <div class="flex h-8 w-8 items-center justify-center rounded-md border border-brand-300/30 bg-brand-300/10 text-xs font-semibold text-brand-100">
          L
        </div>
        <span class="text-base font-semibold text-slate-100">Lithe</span>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-slate-400">
        <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-brand-100">
          {t['footer.github']}
        </a>
        <span class="text-slate-600">·</span>
        <a href={siteConfig.singbox} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-brand-100">
          sing-box
        </a>
        <span class="text-slate-600">·</span>
        <span>{t['footer.license']}</span>
      </div>

      <div class="text-xs text-slate-500">
        {t['footer.thanks']} <a href={siteConfig.singbox} target="_blank" rel="noopener noreferrer" class="text-slate-400 transition-colors hover:text-brand-100">sing-box</a>
      </div>
    </div>
  </div>
</footer>

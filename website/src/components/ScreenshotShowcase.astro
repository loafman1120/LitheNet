---
const { lang, t } = Astro.props;
const base = import.meta.env.BASE_URL || '/';
const normalizedBase = base.endsWith('/') ? base : `${base}/`;
---

<section class="relative overflow-hidden">
  <div class="section-container">
    <div class="reveal text-center">
      <h2 class="section-title">{t['screenshots.title']}</h2>
      <p class="section-subtitle mx-auto">{t['screenshots.desc']}</p>
    </div>

    <div class="reveal reveal-delay-2 mt-14 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="overflow-hidden rounded-lg border border-slate-800 bg-[#0d1318]/78 shadow-2xl shadow-black/20 backdrop-blur-md">
        <div class="flex items-center justify-between border-b border-slate-800 px-4 py-3">
          <span class="font-mono text-xs text-slate-500">active session</span>
          <span class="rounded border border-emerald-300/20 bg-emerald-300/10 px-2 py-1 font-mono text-[11px] text-emerald-200">online</span>
        </div>
        <div class="aspect-video bg-slate-950/35">
          <img
            src={`${normalizedBase}placeholder.svg`}
            alt="LitheNet Application Screenshot"
            class="h-full w-full object-cover opacity-75"
            loading="lazy"
          />
        </div>
      </div>

      <div class="grid content-between gap-4">
        <div class="rounded-lg border border-slate-800 bg-white/[0.015] p-5">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium text-slate-100">Route mode</span>
            <span class="font-mono text-xs text-brand-200">Rule</span>
          </div>
          <div class="mt-5 h-2 overflow-hidden rounded-full bg-slate-800">
            <div class="h-full w-[72%] rounded-full bg-brand-300"></div>
          </div>
          <p class="mt-3 text-xs text-slate-500">Low-noise controls for daily switching and inspection.</p>
        </div>
        <div class="rounded-lg border border-slate-800 bg-white/[0.015] p-5">
          <div class="grid grid-cols-3 gap-3 text-center">
            <div>
              <p class="font-mono text-lg text-white">42</p>
              <p class="mt-1 text-xs text-slate-500">ms</p>
            </div>
            <div>
              <p class="font-mono text-lg text-white">3</p>
              <p class="mt-1 text-xs text-slate-500">groups</p>
            </div>
            <div>
              <p class="font-mono text-lg text-white">0</p>
              <p class="mt-1 text-xs text-slate-500">noise</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { siteConfig } from '../data/site';
import LanguageSwitch from './LanguageSwitch.astro';

const { lang, t } = Astro.props;
const base = import.meta.env.BASE_URL || '/';
const normalizedBase = base.endsWith('/') ? base : `${base}/`;
---

<nav class="fixed top-0 left-0 right-0 z-50 glass">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
    <a href={`${normalizedBase}${lang}/`} class="flex items-center gap-2.5 group">
      <div class="flex h-8 w-8 items-center justify-center rounded-md border border-brand-300/30 bg-brand-300/10 text-xs font-semibold text-brand-100 transition-colors group-hover:bg-brand-300/15">
        LN
      </div>
      <span class="text-base font-semibold text-slate-50">LitheNet</span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      <a href="#features" class="text-sm text-slate-400 transition-colors hover:text-brand-100">
        {t['nav.features']}
      </a>
      <a href="#download" class="text-sm text-slate-400 transition-colors hover:text-brand-100">
        {t['nav.download']}
      </a>
      <a
        href={siteConfig.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-400 transition-colors hover:text-brand-100"
      >
        GitHub
      </a>
      <LanguageSwitch lang={lang} />
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden rounded-md border border-slate-800 p-2 text-slate-400 hover:text-white"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 bg-slate-950/95">
    <div class="flex flex-col gap-3 px-5 py-4">
      <a href="#features" class="text-sm text-slate-400 hover:text-white">{t['nav.features']}</a>
      <a href="#download" class="text-sm text-slate-400 hover:text-white">{t['nav.download']}</a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 hover:text-white">GitHub</a>
      <LanguageSwitch lang={lang} />
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
